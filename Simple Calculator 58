import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) { 
        int a,b,c,d,e,f;
        Scanner s=new Scanner(System.in);
        a=s.nextInt();
        b=s.nextInt();
        c=(a+b);
        d=(a-b);
        e=(a*b);
        f=(a/b);
        System.out.println(c+"\n"+d+"\n"+e+"\n"+f);
    }
}
