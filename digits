import java.util.*;
class Main {
    public static void main(String[] args) 
    {
        Scanner s =new Scanner(System.in);
        System.out.println("Enter a number");
        int num = s.nextInt();
        int p =1 ;
        while (num !=0){
            int d =num%10;
            p*=d;
            num/=10;
        }
         
         
        System.out.println("digits:"+p); 
    }
}
